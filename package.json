  "scripts": {
    "start": "expo start",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "assets:optimize": "powershell -ExecutionPolicy Bypass -File scripts/optimize-mobile-assets.ps1",
